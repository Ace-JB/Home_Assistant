{
  "name": "home-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server/index.ts",
    "start": "NODE_ENV=production bun src/server/index.ts",
    "build": "bun run build.ts",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run build",
    "monitor": "bun --watch src/server/monitor.ts",
    "download_models": "bun run src/server/scripts/load_models.ts"
  },
  "dependencies": {
    "@tensorflow/tfjs-node": "^4.22.0",
    "@vladmandic/human": "^3.3.6",
    "ai": "^3.4.33",
    "bun-plugin-tailwind": "^0.1.2",
    "ollama-ai-provider": "^1.2.0",
    "pipe2jpeg": "^0.5.0",
    "react": "^19",
    "react-dom": "^19",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.3"
  }
}
